# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual API keys.

# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Your Deepgram API key — get one at https://console.deepgram.com ($200 free credits)
DEEPGRAM_API_KEY=

# Optional: change the proxy port (default 3001)
# PROXY_PORT=3001
